{
  "info": {
    "name": "Shop Management System - Phase 3 (Master Data)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "supplier_id", "value": "" },
    { "key": "customer_id", "value": "" },
    { "key": "product_id", "value": "" }
  ],
  "item": [
    {
      "name": "Login (get token first)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) { pm.collectionVariables.set('token', data.token); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        }
      }
    },
    {
      "name": "Category - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.category) { pm.collectionVariables.set('category_id', data.category.category_id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/categories",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Beverages\",\n  \"description\": \"Cold drinks and juices\"\n}" }
      }
    },
    {
      "name": "Category - List / Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/categories?search=bev"
      }
    },
    {
      "name": "Category - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/categories/{{category_id}}",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Beverages\",\n  \"description\": \"Cold drinks, juices, and water\"\n}" }
      }
    },
    {
      "name": "Supplier - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.supplier) { pm.collectionVariables.set('supplier_id', data.supplier.supplier_id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/suppliers",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Fresh Foods Ltd\",\n  \"phone\": \"01700000000\",\n  \"email\": \"contact@freshfoods.com\",\n  \"address\": \"Dhaka, Bangladesh\"\n}" }
      }
    },
    {
      "name": "Supplier - List / Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/suppliers?search=fresh"
      }
    },
    {
      "name": "Customer - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.customer) { pm.collectionVariables.set('customer_id', data.customer.customer_id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/customers",
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rahim Uddin\",\n  \"phone\": \"01800000000\",\n  \"email\": \"rahim@example.com\",\n  \"address\": \"Mirpur, Dhaka\"\n}" }
      }
    },
    {
      "name": "Customer - List / Search",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/customers?search=rahim"
      }
    },
    {
      "name": "Product - Create (with image)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.product) { pm.collectionVariables.set('product_id', data.product.product_id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/products",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Coca-Cola 500ml", "type": "text" },
            { "key": "category_id", "value": "{{category_id}}", "type": "text" },
            { "key": "supplier_id", "value": "{{supplier_id}}", "type": "text" },
            { "key": "cost_price", "value": "35", "type": "text" },
            { "key": "selling_price", "value": "50", "type": "text" },
            { "key": "stock_quantity", "value": "100", "type": "text" },
            { "key": "low_stock_threshold", "value": "20", "type": "text" },
            { "key": "image", "type": "file", "src": [] }
          ]
        }
      }
    },
    {
      "name": "Product - List / Search / Filter",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/products?search=cola&low_stock=false"
      }
    },
    {
      "name": "Product - Get One",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/products/{{product_id}}"
      }
    },
    {
      "name": "Product - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/products/{{product_id}}"
      }
    }
  ]
}
